{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "compaction": {
    "auto": true
  },
  "default_agent": "plan",
  "instructions": [
    "~/.config/opencode/instructions/cli_preferences.md",
  ],
  "model": "deepseek/deepseek-v4-pro",
  "small_model": "deepseek/deepseek-v4-flash",
  "lsp": true,
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "mgrep": {
      "command": [
        "mgrep",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [],
  "provider": {
    
  },
  "snapshot": true
}