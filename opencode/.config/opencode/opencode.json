{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "instructions/code_requirements.md",
    "instructions/cli_preference.md"
  ],
  "compaction": {
    "auto": true
  },
  "autoupdate": true,
  "default_agent": "plan",
  "lsp": true,
  "snapshot": true,
  "mcp": {
    "mgrep": {
      "type": "local",
      "command": [
        "mgrep",
        "mcp"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "opencode-swarm"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}